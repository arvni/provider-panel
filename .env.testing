APP_NAME=Laravel
APP_ENV=testing
APP_KEY=base64:jrA9Mew7oezhFWaole//VukC0P2QSWLpCDOyeEvpD5c=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Isolated test database (created in the provider_mysql container, published on 3307).
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=provider_panel_test
DB_USERNAME=provider
DB_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_DRIVER=array
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=array
SESSION_LIFETIME=120

# Capture mail in-memory; never deliver during tests.
MAIL_MAILER=array

# Email two-factor authentication (login OTP)
TWO_FACTOR_ENABLED=true
TWO_FACTOR_EXPIRY=10
TWO_FACTOR_MAX_ATTEMPTS=5
TWO_FACTOR_RESEND_THROTTLE=60
