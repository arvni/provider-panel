FROM php:8.2-alpine

ENV COMPOSER_ALLOW_SUPERUSER=1 \
    PHP_MEMORY_LIMIT=512M \
    UPLOAD_MAX_FILESIZE=128M \
    POST_MAX_SIZE=128M

RUN apk --no-cache add \
        libzip-dev \
        libpng-dev \
        libsodium-dev \
        jpeg-dev \
        freetype-dev \
        icu-dev \
        oniguruma-dev \
        linux-headers \
        libxml2-dev \
        zlib-dev \
        libmemcached-dev \
        cyrus-sasl-dev \
        g++ \
        make \
        git \
        bash \
        netcat-openbsd \
        nodejs \
        npm \
        $PHPIZE_DEPS && \
    docker-php-ext-configure gd --with-freetype --with-jpeg && \
    docker-php-ext-install -j$(nproc) \
        mysqli \
        pdo_mysql \
        sodium \
        zip \
        gd \
        intl \
        bcmath \
        opcache \
        exif \
        pcntl && \
    pecl install redis memcached && \
    docker-php-ext-enable redis memcached opcache && \
    echo "memory_limit=${PHP_MEMORY_LIMIT}"           >  /usr/local/etc/php/conf.d/app.ini && \
    echo "upload_max_filesize=${UPLOAD_MAX_FILESIZE}" >> /usr/local/etc/php/conf.d/app.ini && \
    echo "post_max_size=${POST_MAX_SIZE}"             >> /usr/local/etc/php/conf.d/app.ini && \
    echo "opcache.enable=1"                           >> /usr/local/etc/php/conf.d/app.ini && \
    echo "opcache.validate_timestamps=1"              >> /usr/local/etc/php/conf.d/app.ini && \
    echo "opcache.revalidate_freq=0"                  >> /usr/local/etc/php/conf.d/app.ini

COPY --from=composer:latest /usr/bin/composer /usr/bin/composer

WORKDIR /app

EXPOSE 8000 5173
